# Copy to .env and fill in. The pipeline reads these as a fallback when the
# value isn't set in config/creators.yaml. Never commit the real .env.

# --- YouTube (Data API v3 + Analytics API v2) ---
YT_CHANNEL_ID=
YT_CLIENT_ID=
YT_CLIENT_SECRET=
YT_REFRESH_TOKEN=
# Optional public-only fallback:
YT_API_KEY=

# --- Instagram (Graph API; Business/Creator account) ---
IG_USER_ID=
IG_ACCESS_TOKEN=

# --- TikTok (for Developers; Display API or Research API) ---
TT_ACCESS_TOKEN=
